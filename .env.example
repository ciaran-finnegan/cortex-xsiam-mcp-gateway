CORTEX_MCP_PAPI_URL=https://api-your-xsiam-tenant.example
CORTEX_MCP_PAPI_AUTH_HEADER=replace-me
CORTEX_MCP_PAPI_AUTH_ID=replace-me

MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_PATH=/api/v1/stream/mcp
MCP_ALLOW_UNAUTHENTICATED_HTTP=false

LOG_SEARCH_DATASET_POLICY={"Security":["*"],"Tier1":["xdr_data"]}
LOG_SEARCH_DEFAULT_PRINCIPAL_ID=service-account
LOG_SEARCH_DEFAULT_GROUPS=
RAW_XQL_PRIVILEGED_GROUPS=Security,Admin
TOOL_ACCESS_POLICY={"Admin":["*"],"Security":["*"],"Tier1":["get_dataset_query_guidance","get_xql_help","list_log_datasets","discover_log_fields","query_dataset","continue_dataset_query","search_logs","get_xql_query_quota","get_cases","get_issues"]}

MCP_IDENTITY_AUTH_MODE=entra
ENTRA_TENANT_ID=
ENTRA_AUDIENCE=api://your-mcp-app-registration
ENTRA_ISSUER=
ENTRA_JWKS_URI=
ENTRA_REQUIRED_SCOPES=
ENTRA_GROUPS_CLAIM=groups
ENTRA_ROLES_CLAIM=roles

MCP_GATEWAY_SHARED_SECRET=
MCP_GATEWAY_ALLOWED_ISSUERS=portkey,litellm
MCP_GATEWAY_MAX_CLOCK_SKEW_SECONDS=300
MCP_GATEWAY_NONCE_CACHE_SIZE=10000

XSIAM_CREDENTIAL_BROKER_ENABLED=false
XSIAM_CREDENTIAL_PROFILES={"Tier1":{"priority":10,"profile_name":"tier1-readonly","api_key_env":"XSIAM_T1_KEY","api_key_id_env":"XSIAM_T1_KEY_ID"}}

DATASET_QUERY_MAX_ROWS=100
DATASET_QUERY_MAX_FIELDS=25
DATASET_QUERY_MAX_FILTERS=20
DATASET_QUERY_MAX_METRICS=8
DATASET_QUERY_MAX_GROUP_FIELDS=5
DATASET_QUERY_MAX_RESPONSE_BYTES=65536
DATASET_QUERY_MAX_CELL_CHARS=2048
DATASET_QUERY_MAX_TIMEFRAME_MS=2592000000
DATASET_QUERY_CURSOR_SECRET=replace-with-a-long-random-secret
DATASET_QUERY_CURSOR_TTL_SECONDS=900
XQL_MAX_CONCURRENT_QUERIES=4
XQL_MAX_QUERY_CHARS=32768

AUDIT_LOG_ENABLED=true
AUDIT_LOG_EMIT_START_EVENTS=true
AUDIT_LOG_INCLUDE_QUERY_TEXT=false
AUDIT_LOG_FAIL_CLOSED=false
AUDIT_LOG_XSIAM_HTTP_COLLECTOR_ENABLED=false
AUDIT_LOG_XSIAM_HTTP_COLLECTOR_URL=https://api-your-xsiam-tenant.example/logs/v1/event
AUDIT_LOG_XSIAM_HTTP_COLLECTOR_API_KEY=replace-with-http-collector-key
